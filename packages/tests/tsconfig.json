{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "paths": {
        "*": [ "../interpreter/src/@types/*"]
    },
    "sourceMap": true,
    "composite": true,
    "declarationMap": true,
    "tsBuildInfoFile": "../../.build-cache/tests.tsbuildinfo",
    "types": [
      "chai",
      "mocha",
      "node"
    ]
  },
  "include": [
    "**/*.ts"
  ],
  "lib": [
    "es2020",
    "dom",
    "es6"
  ],
  "references": [
	  { "path": "../interpreter" }
  ]
}
